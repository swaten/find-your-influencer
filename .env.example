APP_NAME=FindYourInfluencer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

VITE_PORT=5173
PGADMIN_PORT=5050

LOG_CHANNEL=stack
LOG_LEVEL=debug

# these are the HOST-side values - Laravel runs natively (e.g. via XAMPP), so it reaches
# postgres/redis through their docker-published ports, not the internal container network.
# the queue/scheduler containers override these back to postgres:5432 / redis:6379
# in docker-compose.yml, since they run inside the docker network.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=findyourinfluencer
DB_USERNAME=fyi_user
DB_PASSWORD=secret

# host-side port only (docker-compose maps this -> the container's real port 5432)
DB_EXTERNAL_PORT=5432

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:8000,127.0.0.1:8000,localhost:5173,127.0.0.1:5173

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# host-side port only (docker-compose maps this -> the container's real port 6379)
REDIS_EXTERNAL_PORT=6379

FRONTEND_URL=http://localhost:5173

VITE_API_URL=http://localhost:8000

# instagram scraping via apify - apify/instagram-profile-scraper actor
PROFILE_PROVIDER_INSTAGRAM=apify
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-profile-scraper

# youtube also scraped via apify (not the official Data API) - scrapers-hub/youtube-profile-scraper actor
PROFILE_PROVIDER_YOUTUBE=youtube
APIFY_YOUTUBE_ACTOR_ID=scrapers-hub/youtube-profile-scraper

# caps real provider calls/minute regardless of how many profiles are queued
APIFY_RATE_LIMIT_CAPACITY=5
APIFY_RATE_LIMIT_PER_MINUTE=30
YOUTUBE_RATE_LIMIT_CAPACITY=10
YOUTUBE_RATE_LIMIT_PER_MINUTE=100

# shared secret for verifying POST /api/webhooks/apify - generate your own, e.g.
# php -r "echo bin2hex(random_bytes(32));"
APIFY_WEBHOOK_SECRET=
